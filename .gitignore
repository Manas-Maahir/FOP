# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# The local training environment, built by scripts/setup_env.py (~6 GB).
# requirements.lock.txt IS tracked -- it is the record of what actually worked.
.venv/

# Training artifacts. Run directories hold checkpoints (~300 MB each) alongside their
# results.csv and figures; the numbers worth keeping get copied into results*.md.
runs/
work_dirs/
tb_runs/
*.pth
*.pt

# Data (tens of GB raw, ~3.5 GB prepared)
data/
tbx11k_tb512/
TBX11K/
*.zip

# Generated result tables -- regenerated from the run dirs by the notebook's last phase
results_local.md
results_ablation.md

# Source paper (copyrighted; not needed to run anything - paper.md summarises it).
# Delete this line if you want the PDF/DOCX tracked in the repo.
Paper/

# OS
.DS_Store
Thumbs.db
